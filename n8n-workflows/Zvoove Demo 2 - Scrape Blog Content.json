    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const html = $input.item.json.data;\nlet result = {\n  datePublished: null,\n  dateModified: null,\n  author: \"Die Redaktion\", \n  authorUrl: null,\n  image: null,\n  headline: null\n};\n\n// 1. JSON-LD EXTRAKTION\nconst allScripts = html.match(/<script type=\"application\\/ld\\+json\">([\\s\\S]*?)<\\/script>/g);\n\nif (allScripts) {\n  for (let scriptTag of allScripts) {\n    try {\n      const jsonContent = scriptTag.replace(/<script.*?>|<\\/script>/g, '').trim();\n      const jsonLd = JSON.parse(jsonContent);\n      \n      let article = null;\n      if (jsonLd['@type'] === 'Article' || jsonLd['@type'] === 'BlogPosting') {\n        article = jsonLd;\n      } else if (jsonLd['@graph'] && Array.isArray(jsonLd['@graph'])) {\n        article = jsonLd['@graph'].find(item => item['@type'] === 'Article' || item['@type'] === 'BlogPosting');\n      }\n\n      if (article) {\n        result.datePublished = article.datePublished || null;\n        result.dateModified = article.dateModified || null;\n        \n        const rawAuthor = typeof article.author === 'string' ? article.author : (article.author?.name || null);\n        if (rawAuthor && rawAuthor.toLowerCase() !== 'zvoove') {\n          result.author = rawAuthor;\n        }\n\n        result.authorUrl = article.author?.url || null;\n        result.image = article.image?.url || (typeof article.image === 'string' ? article.image : null);\n        result.headline = article.headline || null;\n        break; \n      }\n    } catch (e) { continue; }\n  }\n}\n\n// 2. FALLBACKS (Regex für \"Veröffentlicht: ...\" etc.)\nconst extractIso = (label, htmlText) => {\n  const regex = new RegExp(`${label}:\\\\s*(\\\\d{2})\\\\.(\\\\d{2})\\\\.(\\\\d{4})`, 'i');\n  const match = htmlText.match(regex);\n  return match ? `${match[3]}-${match[2]}-${match[1]}` : null;\n};\n\nif (!result.datePublished) result.datePublished = extractIso('Veröffentlicht', html);\nif (!result.dateModified) result.dateModified = extractIso('Zuletzt geändert', html);\n\n// 3. DATUM CLEANUP & 1970-CHECK\n// Wir bereinigen das Datum nur, wenn es kein Null-Wert ist\nconst cleanDate = (dateStr) => {\n  if (!dateStr || dateStr === \"\" || dateStr === \"null\") return null;\n  // Falls es ein ISO String mit Zeit ist (T12:00...), schneide die Zeit ab\n  if (dateStr.includes('T')) {\n    return dateStr.split('T')[0];\n  }\n  return dateStr;\n};\n\nresult.datePublished = cleanDate(result.datePublished);\nresult.dateModified = cleanDate(result.dateModified);\n\n// Headline Fallback\nif (!result.headline) {\n  const titleMatch = html.match(/<title>(.*?)<\\/title>/i);\n  result.headline = titleMatch ? titleMatch[1].split('|')[0].trim() : null;\n}\n\nreturn result;"
      },
