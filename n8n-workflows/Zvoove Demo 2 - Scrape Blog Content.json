    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const markdown = $input.item.json.data.markdown;\n\n// Strategie 1: Finde H1 (Artikel-Start)\nconst h1Match = markdown.match(/\\n# [^\\n]+/);\nconst h1Index = h1Match ? markdown.indexOf(h1Match[0]) : -1;\n\n// Strategie 2: Footer-Cutoff mit mehreren Fallbacks\nconst cutoffKeywords = [\n  '## Quellen',\n  '## Weiterführende',\n  'Weitere Beiträge',\n  'Sie finden unsere Artikel spannend?',\n  'Diesen Beitrag teilen',\n  'Autor\\n\\n',\n  'Lösungen für',\n  '## Autor',\n  '_Quelle Foto:'\n];\n\nlet cleanedMarkdown = markdown;\n\n// Schritt 1: Schneide ab H1 (wenn gefunden)\nif (h1Index > 0) {\n  cleanedMarkdown = markdown.substring(h1Index).trim();\n} else {\n  // Fallback: Schneide ab erstem H2 wenn kein H1\n  const firstH2Index = markdown.indexOf('\\n## ');\n  if (firstH2Index > 0) {\n    cleanedMarkdown = markdown.substring(firstH2Index).trim();\n  }\n}\n\n// Schritt 2: Finde frühesten Cutoff-Punkt (Footer)\nlet earliestCutoff = cleanedMarkdown.length;\nfor (let keyword of cutoffKeywords) {\n  const cutoffIndex = cleanedMarkdown.indexOf(keyword);\n  if (cutoffIndex > 0 && cutoffIndex < earliestCutoff) {\n    earliestCutoff = cutoffIndex;\n  }\n}\n\n// Schneide beim frühesten Footer-Marker ab\nif (earliestCutoff < cleanedMarkdown.length) {\n  cleanedMarkdown = cleanedMarkdown.substring(0, earliestCutoff).trim();\n}\n\n// Schritt 3: Entferne trailing Whitespace und Newlines\ncleanedMarkdown = cleanedMarkdown.replace(/\\n{3,}/g, '\\n\\n').trim();\n\nreturn {\n  cleanedMarkdown: cleanedMarkdown,\n  originalLength: markdown.length,\n  cleanedLength: cleanedMarkdown.length,\n  reductionPercent: Math.round((1 - cleanedMarkdown.length / markdown.length) * 100)\n};"
      },
