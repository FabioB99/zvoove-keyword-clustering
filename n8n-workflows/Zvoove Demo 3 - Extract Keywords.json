    {
      "parameters": {
        "jsCode": "// Input: Array von Extraction-Outputs\nconst items = $input.all();\nconst allKeywords = [];\n\n// Loop über alle Items\nfor (let i = 0; i < items.length; i++) {\n  const item = items[i];\n  const output = item.json.output; // Extraction Result\n  \n  // Blog Post Metadaten\n  const blogPostId = item.json.id || item.json.fields?.id;\n  const blogPostTitle = item.json.fields?.Headline;\n  const blogPostUrl = item.json.fields?.['Blog URL'];\n  \n  // Primary Keywords\n  if (output.primary_keywords) {\n    for (let keyword of output.primary_keywords) {\n      allKeywords.push({\n        keyword: keyword.toLowerCase(), // ← LOWERCASE\n        category: 'Primary Keyword',\n        search_intent: output.search_intent,\n        source_blog_post_id: blogPostId,\n        source_blog_post_title: blogPostTitle,\n        source_blog_post_url: blogPostUrl\n      });\n    }\n  }\n  \n  // Secondary Keywords\n  if (output.secondary_keywords) {\n    for (let keyword of output.secondary_keywords) {\n      allKeywords.push({\n        keyword: keyword.toLowerCase(), // ← LOWERCASE\n        category: 'Secondary Keyword',\n        search_intent: output.search_intent,\n        source_blog_post_id: blogPostId,\n        source_blog_post_title: blogPostTitle,\n        source_blog_post_url: blogPostUrl\n      });\n    }\n  }\n  \n  // Long-tail Keywords\n  if (output.long_tail_keywords) {\n    for (let keyword of output.long_tail_keywords) {\n      allKeywords.push({\n        keyword: keyword.toLowerCase(), // ← LOWERCASE\n        category: 'Long-tail Keyword',\n        search_intent: output.search_intent,\n        source_blog_post_id: blogPostId,\n        source_blog_post_title: blogPostTitle,\n        source_blog_post_url: blogPostUrl\n      });\n    }\n  }\n}\n\nreturn allKeywords.map(kw => ({ json: kw }));"
      },
