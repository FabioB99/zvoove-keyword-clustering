    {
      "parameters": {
        "jsCode": "// Neue Keywords aus \"Remove duplicates\" Node\nconst newKeywords = $('Remove duplicates in batch').all();\n\n// Bestehende Keywords aus \"Get all existing keywords\" Node\nconst existingKeywords = $('Get all existing keywords').all();\n\n// Erstelle Set mit allen bereits existierenden Keyword-Namen (lowercase)\nconst existingKeywordNames = new Set(\n  existingKeywords.map(item => {\n    // Airtable speichert Daten in fields\n    const keyword = item.json.fields?.Name || \n                   item.json.fields?.Keyword || \n                   item.json.Name || \n                   item.json.Keyword;\n    return keyword ? keyword.toLowerCase().trim() : null;\n  }).filter(Boolean)\n);\n\n// Filtere nur wirklich neue Keywords\nconst uniqueNewKeywords = newKeywords.filter(item => {\n  const keywordName = item.json.keyword?.toLowerCase().trim();\n  \n  // Behalte nur, wenn NICHT in existing vorhanden\n  return keywordName && !existingKeywordNames.has(keywordName);\n});\n\nreturn uniqueNewKeywords;"
      },
